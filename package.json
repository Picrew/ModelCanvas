{
  "name": "modelcanvas",
  "version": "0.1.0",
  "private": true,
  "description": "A protocol-driven rendering bridge for rich model output.",
  "license": "MIT",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "assets": "node scripts/copy-runtime-assets.mjs",
    "predev": "npm run assets",
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "prebuild": "npm run assets",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test tests/e2e/accessibility.spec.ts",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.1",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.5",
    "apache-arrow": "^21.1.0",
    "clsx": "^2.1.1",
    "docx-preview": "^0.4.0",
    "dompurify": "^3.4.11",
    "echarts": "^6.1.0",
    "epubjs": "^0.3.93",
    "exceljs": "^4.4.0",
    "fast-xml-parser": "^5.9.3",
    "katex": "^0.17.0",
    "lucide-react": "^1.24.0",
    "maplibre-gl": "^5.24.0",
    "mermaid": "^11.16.0",
    "next": "^16.2.10",
    "parquet-wasm": "^0.7.2",
    "pdfjs-dist": "^6.1.200",
    "pyodide": "^0.28.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-error-boundary": "^6.1.2",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "three": "^0.185.1",
    "vega": "^6.2.0",
    "vega-embed": "^7.1.0",
    "vega-lite": "^6.4.3",
    "wavesurfer.js": "^7.12.10",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@babel/standalone": "^7.28.5",
    "@cloudflare/vite-plugin": "^1.44.0",
    "@cloudflare/workers-types": "^5.20260711.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "22.19.19",
    "@types/react": "^19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitejs/plugin-rsc": "^0.5.27",
    "@vitest/coverage-v8": "^4.1.10",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  },
  "type": "module",
  "packageManager": "npm@10.9.2",
  "overrides": {
    "@xmldom/xmldom": "0.8.13",
    "lodash-es": "4.18.1",
    "nanoid": "5.1.16",
    "postcss": "8.5.16",
    "uuid": "11.1.1"
  }
}
