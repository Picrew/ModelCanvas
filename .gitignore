# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
playwright-report/
test-results/
/.playwright-cli/

# next.js
/.next/
/.vinext/
/out/
/dist/
/.wrangler/

# misc
.DS_Store
*.pem
.idea/
.vscode/
.eslintcache
*.tsbuildinfo

# debug
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
