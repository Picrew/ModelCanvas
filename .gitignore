# local environment files; keep the documented template
.env
.env.local
.env.*.local
!.env.example

# vercel
.vercel

# typescript
next-env.d.ts

# local build and tool output
/outputs/
/work/
/tmp/
*.inspect.ndjson
/output/
/public/react-artifact-runtime.js
